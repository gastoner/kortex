{
  "name": "cursor",
  "displayName": "Cursor",
  "description": "Integration for Cursor",
  "version": "0.2.0-next",
  "icon": {
    "light": "APP_ICON_2D_LIGHT.png",
    "dark": "APP_ICON_2D_DARK.png"
  },
  "publisher": "kaiden",
  "license": "Apache-2.0",
  "engines": {
    "kaiden": "^0.0.1"
  },
  "main": "./dist/extension.js",
  "source": "./src/extension.ts",
  "contributes": {
    "configuration": {
      "title": "Cursor",
      "properties": {
        "cursor.factory._description": {
          "type": "markdown",
          "scope": "InferenceProviderConnectionFactory",
          "markdownDescription": "Provide a Cursor API key\n\n:button[Grab a key]{href=\"https://cursor.com/settings/api-keys\"}"
        },
        "cursor.factory.apiKey": {
          "type": "string",
          "scope": "InferenceProviderConnectionFactory",
          "description": "Enter your Cursor API key (CURSOR_API_KEY)",
          "format": "password"
        }
      }
    }
  },
  "scripts": {
    "build": "vite build && node ./scripts/build.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "ai": "^6.0.188",
    "inversify": "^7.7.1"
  },
  "devDependencies": {
    "@openkaiden/api": "workspace:*",
    "adm-zip": "^0.5.16",
    "mkdirp": "^3.0.1",
    "vite": "^7.1.2",
    "vitest": "^4.0.10"
  }
}
